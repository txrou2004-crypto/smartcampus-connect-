    {
      "name": "Get ALL Student Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var template = `",
              "<style>",
              "  body { font-family: Arial, sans-serif; padding: 10px; }",
              "  h2 { color: #333; }",
              "  table { border-collapse: collapse; width: 100%; }",
              "  th { background-color: #FF6C37; color: white; padding: 8px 12px; text-align: left; }",
              "  td { padding: 8px 12px; border-bottom: 1px solid #ddd; }",
              "  tr:hover { background-color: #f5f5f5; }",
              "  .badge { padding: 3px 8px; border-radius: 12px; font-size: 12px; font-weight: bold; }",
              "  .active { background-color: #d4edda; color: #155724; }",
              "  .inactive { background-color: #f8d7da; color: #721c24; }",
              "</style>",
              "<h2>Student List</h2>",
              "<table>",
              "  <thead>",
              "    <tr>",
              "      <th>Student ID</th>",
              "      <th>Name</th>",
              "      <th>Email</th>",
              "      <th>Programme</th>",
              "      <th>Status</th>",
              "      <th>Latest GPA</th>",
              "      <th>Latest CGPA</th>",
              "    </tr>",
              "  </thead>",
              "  <tbody>",
              "    {{#each students}}",
              "    <tr>",
              "      <td>{{student_id}}</td>",
              "      <td>{{first_name}} {{last_name}}</td>",
              "      <td>{{email}}</td>",
              "      <td>{{programme_code}}</td>",
              "      <td><span class=\"badge {{statusClass}}\">{{status}}</span></td>",
              "      <td>{{latestGPA}}</td>",
              "      <td>{{latestCGPA}}</td>",
              "    </tr>",
              "    {{/each}}",
              "  </tbody>",
              "</table>",
              "`;",
              "",
              "var responseData = pm.response.json();",
              "",
              "var students = responseData.map(function(s) {",
              "    var records = s.academic_records || [];",
              "    var latest = records.length > 0 ? records[records.length - 1] : null;",
              "    return {",
              "        student_id: s.student_id,",
              "        first_name: s.first_name,",
              "        last_name: s.last_name,",
              "        email: s.email,",
              "        programme_code: s.programme_code,",
              "        status: s.status,",
              "        statusClass: s.status === 'ACTIVE' ? 'active' : 'inactive',",
              "        latestGPA: latest ? latest.gpa : 'N/A',",
              "        latestCGPA: latest ? latest.cgpa : 'N/A'",
              "    };",
              "});",
              "",
              "pm.visualizer.set(template, { students: students });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
